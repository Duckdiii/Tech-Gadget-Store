# =============================================================================
# TechGadgetStore - Environment Variable Template
# =============================================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control — it is listed in .gitignore.
# =============================================================================

# --- Database (Supabase PostgreSQL) ------------------------------------------
DB_URL=jdbc:postgresql://<host>:<port>/postgres?sslmode=require
DB_USERNAME=postgres.<your-project-ref>
DB_PASSWORD=<your-db-password>

# --- Email (Gmail SMTP) -------------------------------------------------------
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=465
EMAIL_SMTP_USER=<your-gmail-address>
EMAIL_SMTP_PASS=<your-gmail-app-password>
EMAIL_FROM_NAME=TechStore System
EMAIL_FROM_ADDRESS=<your-gmail-address>
EMAIL_REPLY_TO_MODE=customer
EMAIL_REPLY_TO_ADDRESS=

# --- JWT ----------------------------------------------------------------------
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=<your-long-random-jwt-secret>

# --- MoMo Payment Gateway (Sandbox) ------------------------------------------
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_PARTNER_CODE=<your-momo-partner-code>
MOMO_ACCESS_KEY=<your-momo-access-key>
MOMO_SECRET_KEY=<your-momo-secret-key>
MOMO_REDIRECT_URL=http://localhost:8080/api/payments/momo/return
MOMO_IPN_URL=https://<your-ngrok-or-domain>/api/payments/momo/ipn

# --- VNPay Payment Gateway (Sandbox) -----------------------------------------
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_TMN_CODE=<your-vnpay-tmn-code>
VNPAY_HASH_SECRET=<your-vnpay-hash-secret>
VNPAY_RETURN_URL=https://<your-ngrok-or-domain>/api/payments/vnpay/return
VNPAY_IPN_URL=https://<your-ngrok-or-domain>/api/payments/vnpay/ipn
